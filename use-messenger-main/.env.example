# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-secret-key-change-in-production

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=https://localhost:4000,https://127.0.0.1:4000

# For production, replace with your server IP
# ALLOWED_ORIGINS=https://<SERVER_IP>:4000

# SSL Certificate paths (optional, for HTTPS)
# SSL_CERT_FILE=/app/ssl/cert.pem
# SSL_KEY_FILE=/app/ssl/key.pem
